# ============================================================================
# FRONTEND ENVIRONMENT CONFIGURATION
# ============================================================================
# This file contains all environment variables needed for the React frontend.
# Copy this file to .env and update values for your environment.
#
# Development: .env (gitignored, contains local secrets)
# Example: .env.example (tracked in git, no secrets)
# ============================================================================

# ========== API CONFIGURATION ==========
# Backend API URL for all API requests from the frontend

# Development: Backend running on localhost:3000
VITE_API_URL=http://localhost:3000/api
VITE_API_BASE_URL=http://localhost:3000

# Production (Docker): Backend running on backend service
# VITE_API_URL=http://backend:3000/api
# VITE_API_BASE_URL=http://backend:3000

# ========== APPLICATION MODE ==========
# Development or production build
NODE_ENV=development

# ========== FEATURE FLAGS ==========
# Enable/disable features for different environments
VITE_DEBUG_MODE=true
VITE_ENABLE_MOCK_DATA=false
